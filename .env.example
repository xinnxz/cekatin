# ============================================================
# CekatIn — Environment Variables Template
# ============================================================
# SALIN file ini menjadi .env dan isi nilainya.
# JANGAN PERNAH men-commit file .env asli Anda!

# ── General Settings ──
PORT=5000
FLASK_DEBUG=false
AGENT_NAME="Cika"

# ── Database ──
# (PostgreSQL DSN example: postgresql://user:password@localhost:5432/cekatin)
DATABASE_URL=sqlite:///cekatin.db

# ── Security & Authentication ──
SECRET_KEY=ganti_dengan_secret_key_jwt_yang_panjang_dan_aman
JWT_EXPIRY_HOURS=24
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# ── AI API Keys: GEMINI (Primary Provider) ──
# Dapatkan di: https://aistudio.google.com/apikey
# Anda bisa memakai single key atau multi-key rotation
GEMINI_API_KEY=your_gemini_key_here
# GEMINI_API_KEY_1=your_first_gemini_key
# GEMINI_API_KEY_2=your_second_gemini_key

# ── AI API Keys: GROQ (Fallback Provider) ──
# Dapatkan di: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here
# GROQ_API_KEY_1=gsk_your_groq_key_here

# ── Meta / WhatsApp Cloud API ──
# Dapatkan dari Facebook Developer Console
WA_VERIFY_TOKEN=cekatin_webhook_verify_2026
WA_ACCESS_TOKEN=your_whatsapp_access_token
WA_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WA_BUSINESS_ACCOUNT_ID=your_whatsapp_business_account_id

# ── Email Settings (SMTP) ──
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465
EMAIL_FROM=your_email@gmail.com
EMAIL_FROM_NAME="Cepat Chat Support"
EMAIL_PASSWORD=your_app_password
