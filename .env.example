# ============================================================
# CekatIn — Environment Variables
# ============================================================
# Copy file ini ke .env dan isi dengan API key kamu

# ── GEMINI (Primary Provider) ──
# Dapatkan di: https://aistudio.google.com/apikey
#
# Multi-key rotation:
# GEMINI_API_KEY_1=your_gemini_key_here
# GEMINI_API_KEY_2=your_gemini_key_here
#
# Atau single key:
# GEMINI_API_KEY=your_gemini_key_here

# ── GROQ (Fallback Provider — 14.400 RPD GRATIS!) ──
# Dapatkan di: https://console.groq.com
#
# Multi-key rotation:
# GROQ_API_KEY_1=gsk_your_groq_key_here
# GROQ_API_KEY_2=gsk_your_groq_key_here
#
# Atau single key:
# GROQ_API_KEY=gsk_your_groq_key_here
