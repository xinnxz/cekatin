# ============================================
# CekatIn - .gitignore
# ============================================
# File ini memberitahu Git file mana yang TIDAK BOLEH
# di-push ke GitHub. Terutama file sensitif seperti API key.

# ── Environment & API Keys (PENTING!) ──
.env
.env.local
.env.production

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
venv/
env/
.venv/

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ──
.DS_Store
Thumbs.db
desktop.ini

# ── Documents & Images (ga perlu di GitHub) ──
*.docx
*.doc
*.pdf
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.bmp
*.svg
docs/
evaluation_results/

# ── Scripts yang ga perlu di-deploy ──
_check_kb.py
_trim_kb.py
evaluate.py
expand_patterns.py
generate_flowchart.py
integrate_smartphones.py
test_kb.py
test_suggest.py
journal_paper_structure.md

# ── Database (lokal, jangan push) ──
*.db
*.sqlite3
migrate_json_to_db.py
