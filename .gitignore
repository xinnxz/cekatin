# ============================================
# CekatIn - .gitignore
# ============================================
# File ini memberitahu Git file mana yang TIDAK BOLEH
# di-push ke GitHub. Terutama file sensitif seperti API key.

# ── Environment & API Keys (PENTING!) ──
.env
.env.local
.env.production

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
venv/
env/
.venv/

# ── Model Files ──
# JANGAN ignore! Dibutuhkan Render untuk deploy
# models/*.pkl  ← dikomment karena perlu untuk deployment
# models/*.joblib

# ── Data yang tidak perlu di GitHub ──
dataset/learning_log.json
journal_paper_structure.md

# ── Evaluation Results ──
evaluation_results/

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ──
.DS_Store
Thumbs.db
desktop.ini

# ── Documents & Images (ga perlu di GitHub) ──
*.docx
*.doc
*.pdf
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.bmp
*.svg
docs/
evaluation_results/
